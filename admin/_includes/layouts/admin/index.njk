---
layout: layouts/base.njk
title: ہوم پیج
pagination:
  data: collections.blog
  size: 6
  alias: posts
---

<div class="row">
  {% for post in posts %}
    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <img src="{{ post.data.image }}" class="card-img-top" alt="{{ post.data.title }}">
        <div class="card-body">
          <h5><a href="{{ post.url }}">{{ post.data.title }}</a></h5>
          <p class="small text-muted">{{ post.data.date | readableDate }} | {{ post.data.category }}</p>
        </div>
      </div>
    </div>
  {% endfor %}
</div>

<nav>
  <ul class="pagination justify-content-center">
    {% if pagination.href.previous %}<li class="page-item"><a class="page-item" href="{{ pagination.href.previous }}">پچھلا</a></li>{% endif %}
    {% if pagination.href.next %}<li class="page-item"><a class="page-item" href="{{ pagination.href.next }}">اگلا</a></li>{% endif %}
  </ul>
</nav>
