<!DOCTYPE html>
<html lang="ur" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | My Blog</title>
    <meta name="description" content="{{ description }}">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    
    <style>
        :root { --bg: #ffffff; --text: #212529; }
        [data-theme="dark"] { --bg: #121212; --text: #e0e0e0; }
        body { background-color: var(--bg); color: var(--text); transition: 0.3s; }
        .navbar { border-bottom: 1px solid #ddd; }
        {{ customCSS | safe }}
    </style>
</head>
<body data-theme="light">
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/">My CMS Blog</a>
            <button class="btn btn-sm btn-outline-secondary" id="theme-toggle">تیم تبدیل کریں</button>
        </div>
    </nav>

    <main class="container mt-5">
        {{ content | safe }}
    </main>

    <footer class="text-center mt-5 py-4 border-top">
        <p>&copy; 2026 جملہ حقوق محفوظ ہیں۔</p>
    </footer>

    <script>
        const btn = document.getElementById("theme-toggle");
        btn.onclick = () => {
            const current = document.body.getAttribute("data-theme");
            document.body.setAttribute("data-theme", current === "dark" ? "light" : "dark");
        };
    </script>
    <script>{{ customJS | safe }}</script>
</body>
</html>
